# Connection string PostgreSQL. Untuk development, bisa pakai:
# - Neon (neon.tech) — gratis, serverless Postgres, paling mudah untuk Next.js
# - Supabase (supabase.com) — gratis, sudah termasuk storage juga
# - Docker lokal: postgresql://user:password@localhost:5432/file.db
DATABASE_URL=""

# Generate dengan: npx auth secret
AUTH_SECRET=""

# GitHub OAuth — buat di https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://domainkamu.com/api/auth/callback/github (production)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Discord OAuth — buat di https://discord.com/developers/applications
# Callback URL: http://localhost:3000/api/auth/callback/discord (dev)
#               https://domainkamu.com/api/auth/callback/discord (production)
# Scope yang dipakai: identify + email (lihat lib/auth.ts)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Google OAuth — buat di https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google (dev)
#               https://domainkamu.com/api/auth/callback/google (production)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============================================================================
# EMAIL OTOMATIS — verifikasi email, reset password, ganti email, dan
# notifikasi form contact. Pakai Resend (https://resend.com).
# Kalau RESEND_API_KEY kosong, email otomatis dicetak ke console server
# (lihat lib/mail.ts) — jadi seluruh flow tetap bisa dites di lokal tanpa
# akun Resend.
# ============================================================================
RESEND_API_KEY=""
MAIL_FROM_ADDRESS="no-reply@domainkamu.com"

# ============================================================================
# Email Admin pertama. User dengan email ini otomatis diset role ADMIN
# saat pertama kali login (lihat lib/auth.ts -> signIn callback).
# ============================================================================
ADMIN_BOOTSTRAP_EMAIL=""

# ============================================================================
# CLOUDINARY — penyimpanan file untuk avatar, banner, gallery project, dan
# Media Manager. Daftar gratis di https://cloudinary.com/users/register/free
# Setelah daftar, ketiga nilai ini ada di Dashboard utama Cloudinary
# (langsung kelihatan setelah login, tidak perlu konfigurasi tambahan).
# ============================================================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""